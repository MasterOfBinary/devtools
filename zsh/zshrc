# ~/.zshrc - Minimal zsh configuration with Pure prompt

# ------------------------------------------------------------------------------
# ENVIRONMENT
# ------------------------------------------------------------------------------
export EDITOR='nvim'
export LANG='en_US.UTF-8'

# Local binaries
export PATH="$HOME/.local/bin:$PATH"

# Devtools directory
export DT_DIR="$HOME/.devtools"

# ------------------------------------------------------------------------------
# HISTORY
# ------------------------------------------------------------------------------
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt appendhistory     # Append to history
setopt sharehistory      # Share history across all sessions
setopt incappendhistory  # Append to history file immediately
setopt hist_ignore_dups  # Don't record dupes in history
setopt hist_ignore_space # Don't record commands starting with a space

# ------------------------------------------------------------------------------
# COMPLETIONS
# ------------------------------------------------------------------------------
# Add plugins and prompt to fpath
fpath=(~/.zsh/plugins/zsh-completions/src ~/.zsh/prompt/pure $fpath)

# Initialize completions
autoload -U compinit && compinit
zstyle ':completion:*' menu select
# Only show immediate subdirectories for cd
zstyle ':completion:*:cd:*' tag-order local-directories

# ------------------------------------------------------------------------------
# PLUGIN SOURCING
# ------------------------------------------------------------------------------
# Source plugins if they exist
[ -f ~/.zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] && \
    source ~/.zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

[ -f ~/.zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ] && \
    source ~/.zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh

# Make autosuggestions smarter - prefer history entries that would work in current context
ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# ------------------------------------------------------------------------------
# PROMPT
# ------------------------------------------------------------------------------
# Load Pure prompt
autoload -U promptinit && promptinit
prompt pure

# ------------------------------------------------------------------------------
# NAVIGATION
# ------------------------------------------------------------------------------
# Initialize zoxide (better z)
command -v zoxide &> /dev/null && eval "$(zoxide init zsh)"

# ------------------------------------------------------------------------------
# ALIASES
# ------------------------------------------------------------------------------
# Source personal aliases
[ -f ~/.zsh/aliases.zsh ] && source ~/.zsh/aliases.zsh

# ------------------------------------------------------------------------------
# CUSTOM ENVIRONMENT
# ------------------------------------------------------------------------------
# Source custom environment variables (API keys, paths, etc)
[ -f ~/.zsh/custom-env.zsh ] && source ~/.zsh/custom-env.zsh

# ------------------------------------------------------------------------------
# LAST WORKING DIRECTORY
# ------------------------------------------------------------------------------
if [[ -f ~/.last-working-dir && -d "$(cat ~/.last-working-dir)" ]]; then
  cd "$(cat ~/.last-working-dir)"
fi

chpwd() {
  pwd > ~/.last-working-dir
}

# ------------------------------------------------------------------------------
# OPTIONS
# ------------------------------------------------------------------------------
# Turn off auto-pushd
unsetopt autopushd